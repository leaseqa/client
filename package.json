{
  "name": "leaseqa-monorepo",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.2",
  "scripts": {
    "dev": "npm run dev --workspace @leaseqa/web",
    "build": "npm run build --workspace @leaseqa/web",
    "lint": "npm run lint --workspace @leaseqa/web",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": "20.x"
  },
  "devDependencies": {
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "react-redux": "^9.2.0"
  }
}
